generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EmploymentStatus {
  PERMANENT
  COS
  JO
}

enum Role {
  STAFF
  DIVISION_HEAD
  APCO
  CHIEF_AGRICULTURIST
  CHIEF_ADMINISTRATIVE
  REGIONAL_EXECUTIVE
  HR
  ADMIN
}

enum RequestStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  HR_PROCESSING
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  CHECKING
  APPROVED
  REJECTED
}

model User {
  id               String           @id @default(uuid())
  firstName        String
  middleInitial    String?
  lastName         String
  email            String           @unique
  mobileNumber     String
  employmentStatus EmploymentStatus?
  division         String?
  officialStation  String?
  savedSignature   String?
  password         String
  role             Role             @default(STAFF)

  travelOrders     TravelOrderRequest[]  
  approvals        Approval[]            
  auditLogs        AuditLog[]           
  notifications    Notification[]       
  hrProcessedOrders TravelOrderRequest[] @relation("HRAssignments") 
  attachments      Attachment[]         

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("users")
}

model TravelOrderRequest {
  id                     String        @id @default(uuid())
  travelOrderNumber      String?       @unique

  requestorName          String
  requestorPosition      String
  requestorSalary        String
  requestorStation       String
  employmentStatus       EmploymentStatus

  // Foreign key to the user who created it
  userId                 String
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Travel details
  purpose                String        @db.Text
  destinationProvince    String
  specificLocation       String
  departureDate          DateTime
  returnDate             DateTime
  meansOfTransport       String
  estimatedExpenses      String
  sourceOfFunds          String
  accompanyingPersonnel  String?

  // Additional detailed fields
  destinationSummary     String        @db.Text
  objectives             String        @db.Text
  travelDetails          String        @db.Text

  // Workflow tracking
  status                 RequestStatus @default(PENDING)
  rejectionReason        String?       @db.Text

  // HR actions
  hrProcessedAt          DateTime?
  hrUserId               String?
  hrUser                 User?         @relation("HRAssignments", fields: [hrUserId], references: [id])

  // Relations to other models
  approvals              Approval[]
  attachments            Attachment[]
  auditLogs              AuditLog[]    @relation("TravelOrderAuditLogs")
  notifications          Notification[] @relation("TravelOrderNotifications")

  itineraryItems         ItineraryItem[]

  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("travel_orders")
}

model ItineraryItem {
  id                String             @id @default(uuid())
  
  travelOrderId     String
  travelOrder       TravelOrderRequest @relation(fields: [travelOrderId], references: [id], onDelete: Cascade)
  
  date              DateTime
  location          String             @db.Text
  activity          String             @db.Text
  responsiblePerson String

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("itinerary_items")
}

model Approval {
  id                     String        @id @default(uuid())
  travelOrderId          String
  travelOrder            TravelOrderRequest @relation(fields: [travelOrderId], references: [id], onDelete: Cascade)
  approverRole           Role
  approverId             String?
  approver               User?         @relation(fields: [approverId], references: [id])
  status                 ApprovalStatus @default(PENDING)
  comment                String?       @db.Text
  signatureData          String?       // base64 or URL of the signature image
  certificationCheck     Boolean       @default(false)
  placeSigned            String?       // e.g., "DA Calapan City"
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([travelOrderId, approverRole])
  @@map("approvals")
}

model Attachment {
  id                     String        @id @default(uuid())
  travelOrderId          String
  travelOrder            TravelOrderRequest @relation(fields: [travelOrderId], references: [id], onDelete: Cascade)

  fileName               String
  fileUrl                String
  fileSize               Int
  mimeType               String

  uploadedById           String
  uploadedBy             User          @relation(fields: [uploadedById], references: [id])

  createdAt              DateTime      @default(now())

  @@map("attachments")
}

model AuditLog {
  id                     String        @id @default(uuid())
  userId                 String
  user                   User          @relation(fields: [userId], references: [id])

  action                 String
  details                String?       @db.Text
  ipAddress              String?
  userAgent              String?

  travelOrderId          String?
  travelOrder            TravelOrderRequest? @relation("TravelOrderAuditLogs", fields: [travelOrderId], references: [id])

  createdAt              DateTime      @default(now())

  @@map("audit_logs")
}

model Notification {
  id                     String        @id @default(uuid())
  userId                 String
  user                   User          @relation(fields: [userId], references: [id])

  type                   String
  title                  String
  message                String        @db.Text
  isRead                 Boolean       @default(false)
  link                   String?

  travelOrderId          String?
  travelOrder            TravelOrderRequest? @relation("TravelOrderNotifications", fields: [travelOrderId], references: [id])

  createdAt              DateTime      @default(now())

  @@map("notifications")
}