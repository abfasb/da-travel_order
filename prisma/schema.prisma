generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EmploymentStatus {
  PERMANENT
  COS
  JO
}

enum Role {
  STAFF
  APCO
  CHIEF_AGRICULTURIST
  CHIEF_ADMINISTRATIVE
  REGIONAL_EXECUTIVE
  HR
  ADMIN
}

enum RequestStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

model User {
  id               String           @id @default(uuid())
  firstName        String
  middleInitial    String?
  lastName         String
  email            String           @unique
  mobileNumber     String
  employmentStatus EmploymentStatus
  division         String
  officialStation  String
  password         String           

  role             Role             @default(STAFF)
  
  travelOrders     TravelOrderRequest[]
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("users") 
}

model TravelOrderRequest {
  id                     String        @id @default(uuid())
  
  // Foreign Key
  userId                 String
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                   String
  salaryPerMonth         String        
  position               String
  // REMOVED officialStation here!

  departureDate          DateTime
  returnDate             DateTime
  
  destinationProvince    String
  specificLocation       String
  destination            String        
  
  specificPurpose        String        @db.Text
  objectives             String        @db.Text
  travelDetails          String        @db.Text

  meansOfTransportation  String
  estimatedExpenses      String        
  sourceOfFunds          String
  accompanyingPersonnel  String?       

  status                 RequestStatus @default(PENDING)

  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("travel_orders")
}